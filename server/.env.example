# Sarvam AI API subscription key (https://dashboard.sarvam.ai → API Keys)
SARVAM_API_KEY=your_sarvam_api_subscription_key

# Chat model for call analysis (Score/Summary). Default sarvam-m; bump to
# sarvam-30b or sarvam-105b for stronger structured-JSON scoring.
SARVAM_CHAT_MODEL=sarvam-m

# Postgres connection string. Use your Supabase Postgres URI
# (Supabase dashboard → Project Settings → Database → Connection string → URI).
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/leadpilot

# HTTP port the backend listens on.
PORT=3000
